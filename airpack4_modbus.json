      { "hex": "0x0111", "dec": 273, "access": "R", "name": "exhaust_percentage",    "description": "Zadana intensywność wentylacji (wywiew)", "min": 0, "max": 150, "unit": "%", "fw": "2.15" },
      { "hex": "0x0112", "dec": 274, "access": "R", "name": "supply_flowrate",       "description": "Zadany strumień przepływu (nawiew)",     "min": 0, "max": 4095, "unit": "m3/h", "fw": "2.15" },
      { "hex": "0x0113", "dec": 275, "access": "R", "name": "exhaust_flowrate",      "description": "Zadany strumień przepływu (wywiew)",     "min": 0, "max": 4095, "unit": "m3/h", "fw": "2.15" },
      { "hex": "0x0114", "dec": 276, "access": "R", "name": "min_percentage",        "description": "Minimalna możliwa intensywność wentylacji", "unit": "%", "fw": "2.15" },
      { "hex": "0x0115", "dec": 277, "access": "R", "name": "max_percentage",        "description": "Maksymalna możliwa intensywność wentylacji", "unit": "%", "fw": "2.15" }
    ]
