{
  "device": "AirPack4",
  "protocol": "Modbus RTU",
  "connection": {
    "baud_rate": 9600,
    "data_bits": 8,
    "parity": "N",
    "stop_bits": 1,
    "max_registers_per_read": 16
  },
  "notes": {
    "rw": "Read and Write",
    "ro": "Read Only",
    "address_format": "0x1A2B = register number (hex)",
    "value_format": "0x1a2b = value stored in register"
  },

  "coils_01": {
    "description": "READ COILS (FC01)",
    "registers": [
      { "hex": "0x0005", "dec": 5,  "access": "R", "name": "duct_warter_heater_pump", "description": "Stan wyjścia przekaźnika pompy obiegowej nagrzewnicy", "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0009", "dec": 9,  "access": "R", "name": "bypass",                  "description": "Stan wyjścia siłownika przepustnicy bypass",             "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000A", "dec": 10, "access": "R", "name": "info",                    "description": "Stan wyjścia sygnału potwierdzenia pracy centrali (O1)",  "values": {"0": "OFF", "1": "ON"}, "fw": "4.84" },
      { "hex": "0x000B", "dec": 11, "access": "R", "name": "power_supply_fans",       "description": "Stan wyjścia przekaźnika zasilania wentylatorów",          "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000C", "dec": 12, "access": "R", "name": "heating_cable",           "description": "Stan wyjścia przekaźnika zasilania kabla grzejnego",       "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000D", "dec": 13, "access": "R", "name": "workt_permit",            "description": "Stan wyjścia przekaźnika potwierdzenia pracy (Expansion)", "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000E", "dec": 14, "access": "R", "name": "gwc",                    "description": "Stan wyjścia przekaźnika GWC",                            "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000F", "dec": 15, "access": "R", "name": "hood",                   "description": "Stan wyjścia zasilającego przepustnicę okapu",             "values": {"0": "OFF", "1": "ON"} }
    ]
  },

  "discrete_inputs_02": {
    "description": "READ DISCRETE INPUTS (FC02)",
    "registers": [
      { "hex": "0x0000", "dec": 0,  "access": "R", "name": "duct_heater_protection",  "description": "Stan wejścia zabezpieczenia termicznego elektrycznej nagrzewnicy kanałowej", "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0001", "dec": 1,  "access": "R", "name": "expansion",               "description": "Komunikacja z modułem Expansion",                        "values": {"0": "brak", "1": "jest"} },
      { "hex": "0x0003", "dec": 3,  "access": "R", "name": "dp_duct_filter_overflow", "description": "Stan wejścia presostatu filtra kanałowego",               "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0004", "dec": 4,  "access": "R", "name": "hood",                   "description": "Stan wejścia włącznika funkcji OKAP",                    "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0005", "dec": 5,  "access": "R", "name": "contamination_sensor",   "description": "Stan wejścia dwustanowego czujnika jakości powietrza",    "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0006", "dec": 6,  "access": "R", "name": "airing_sensor",          "description": "Stan wejścia dwustanowego czujnika wilgotności",          "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0007", "dec": 7,  "access": "R", "name": "airing_switch",          "description": "Stan wejścia włącznika funkcji WIETRZENIE",               "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000A", "dec": 10, "access": "R", "name": "airing_mini",            "description": "Stan wejścia przełącznika AirS w pozycji 'Wietrzenie'",  "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000B", "dec": 11, "access": "R", "name": "fan_speed_3",            "description": "Stan wejścia przełącznika AirS w pozycji '3 bieg'",      "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000C", "dec": 12, "access": "R", "name": "fan_speed_2",            "description": "Stan wejścia przełącznika AirS w pozycji '2 bieg'",      "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000D", "dec": 13, "access": "R", "name": "fan_speed_1",            "description": "Stan wejścia przełącznika AirS w pozycji '1 bieg'",      "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000E", "dec": 14, "access": "R", "name": "fireplace",              "description": "Stan wejścia włącznika funkcji KOMINEK",                  "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x000F", "dec": 15, "access": "R", "name": "ppoz",                  "description": "Stan wejścia sygnału alarmu pożarowego (P.POZ.)",         "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0012", "dec": 18, "access": "R", "name": "dp_ahu_filter_overflow", "description": "Stan wejścia presostatu filtrów w rekuperatorze (DP1)",   "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0013", "dec": 19, "access": "R", "name": "ahu_filter_protection",  "description": "Stan wejścia zabezpieczenia termicznego nagrzewnicy systemu przeciwzamrożeniowego FPX", "values": {"0": "OFF", "1": "ON"} },
      { "hex": "0x0015", "dec": 21, "access": "R", "name": "empty_house",            "description": "Stan wejścia sygnału załączenia funkcji PUSTY DOM",       "values": {"0": "OFF", "1": "ON"} }
    ]
  },

  "input_registers_04": {
    "description": "READ INPUT REGISTERS (FC04)",
    "registers": [
      { "hex": "0x0000", "dec": 0,   "access": "R", "name": "VERSION_MAJOR",         "description": "Wersja oprogramowania - liczba 1 [MM]", "unit": null },
      { "hex": "0x0001", "dec": 1,   "access": "R", "name": "VERSION_MINOR",         "description": "Wersja oprogramowania - liczba 2 [mm]", "unit": null },
      { "hex": "0x0002", "dec": 2,   "access": "R", "name": "day_of_week",           "description": "Bieżący dzień tygodnia dla trybu automatycznego", "min": 0, "max": 6, "values": {"0": "Poniedziałek", "1": "Wtorek", "2": "Środa", "3": "Czwartek", "4": "Piątek", "5": "Sobota", "6": "Niedziela"} },
      { "hex": "0x0003", "dec": 3,   "access": "R", "name": "period",                "description": "Bieżący odcinek czasowy dla trybu automatycznego", "min": 0, "max": 3, "values": {"0": "Odcinek 1", "1": "Odcinek 2", "2": "Odcinek 3", "3": "Odcinek 4"} },
      { "hex": "0x0004", "dec": 4,   "access": "R", "name": "VERSION_PATCH",         "description": "Wersja oprogramowania - liczba 3 [pp]" },
      { "hex": "0x000E", "dec": 14,  "access": "R", "name": "compilation_days",      "description": "Data kompilacji oprogramowania Basic (dni od 01.01.2000)", "unit": "days" },
      { "hex": "0x000F", "dec": 15,  "access": "R", "name": "compilation_seconds",   "description": "Godzina kompilacji oprogramowania (sekundy od 00:00:00)", "multiplier": 2, "unit": "s" },
      { "hex": "0x0010", "dec": 16,  "access": "R", "name": "outside_temperature",   "description": "Temperatura powietrza zewnętrznego TZ1", "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0011", "dec": 17,  "access": "R", "name": "supply_temperature",    "description": "Temperatura powietrza nawiewanego TN1",  "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0012", "dec": 18,  "access": "R", "name": "exhaust_temperature",   "description": "Temperatura powietrza usuwanego TP",     "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0013", "dec": 19,  "access": "R", "name": "fpx_temperature",       "description": "Temperatura powietrza za nagrzewnicą FPX TZ2", "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0014", "dec": 20,  "access": "R", "name": "duct_supply_temperature","description": "Temperatura powietrza za nagrzewnicą/chłodnicą kanałową TN2", "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0015", "dec": 21,  "access": "R", "name": "gwc_temperature",       "description": "Temperatura przed wymiennikiem GWC TZ3",  "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0016", "dec": 22,  "access": "R", "name": "ambient_temperature",   "description": "Temperatura otoczenia TO",               "min": -999, "max": 999, "multiplier": 0.1, "unit": "°C", "note": "0x8000 = brak odczytu" },
      { "hex": "0x0018", "dec": 24,  "access": "R", "name": "serial_number_1",       "description": "Numer seryjny sterownika - słowo 1" },
      { "hex": "0x0019", "dec": 25,  "access": "R", "name": "serial_number_2",       "description": "Numer seryjny sterownika - słowo 2" },
      { "hex": "0x001A", "dec": 26,  "access": "R", "name": "serial_number_3",       "description": "Numer seryjny sterownika - słowo 3" },
      { "hex": "0x001B", "dec": 27,  "access": "R", "name": "serial_number_4",       "description": "Numer seryjny sterownika - słowo 4" },
      { "hex": "0x001C", "dec": 28,  "access": "R", "name": "serial_number_5",       "description": "Numer seryjny sterownika - słowo 5" },
      { "hex": "0x001D", "dec": 29,  "access": "R", "name": "serial_number_6",       "description": "Numer seryjny sterownika - słowo 6" },
